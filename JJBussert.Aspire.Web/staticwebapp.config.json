{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/users",
      "methods": ["POST", "PUT", "DELETE"],
      "allowedRoles": ["Admin"]
    },
    {
      "route": "/api/organizations",
      "methods": ["POST", "PUT", "DELETE"],
      "allowedRoles": ["Admin"]
    }
  ],
  "auth": {
    "rolesSource": "/api/.auth/me",
    "identityProviders": {
      "customOpenIdConnectProviders": {}
    }
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  }
}
